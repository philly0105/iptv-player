# =============================================================================
# IPTV Player — Environment Variables
# Copy this file to .env and fill in real values before running.
# Never commit .env to source control.
# =============================================================================

# ---- Required in production -------------------------------------------------

# Secret used to sign JWT tokens.
# Generate a strong random value, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret

# Secret used to sign express-session cookies.
# Must be different from JWT_SECRET.
SESSION_SECRET=CHANGE_ME_generate_another_long_random_secret

# ---- Optional ---------------------------------------------------------------

# Server port (default: 3000)
PORT=3000

# Set to 'production' to enforce required secrets and disable dev-mode warnings.
NODE_ENV=production

# ---- Default IPTV source (optional — auto-added on first launch if set) -----

# Xtream Codes credentials seeded automatically when the DB has no sources.
# IPTV_DEFAULT_NAME=My IPTV
# IPTV_DEFAULT_HOST=http://your-provider.example.com
# IPTV_DEFAULT_USER=your_username
# IPTV_DEFAULT_PASS=your_password

# ---- OIDC / SSO (optional — leave unset to disable SSO) --------------------

# URL of your OpenID Connect provider (e.g. Keycloak, Auth0, Google).
# OIDC_ISSUER_URL=https://your-idp.example.com/realms/myrealm

# Client credentials registered with your OIDC provider.
# OIDC_CLIENT_ID=iptv-player
# OIDC_CLIENT_SECRET=CHANGE_ME

# Override individual OIDC endpoints (optional — derived from issuer URL by default).
# OIDC_AUTH_URL=
# OIDC_TOKEN_URL=
# OIDC_USERINFO_URL=

# Public-facing callback URL that your OIDC provider will redirect to after login.
# OIDC_CALLBACK_URL=https://your-iptv.example.com/api/auth/oidc/callback
